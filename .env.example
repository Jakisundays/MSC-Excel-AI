# ─────────────────────────────────────────────────────────────
# PocketBase (Pockethost)
# ─────────────────────────────────────────────────────────────
# URL pública de tu instancia de Pockethost
NEXT_PUBLIC_POCKETBASE_URL=https://msc-excel-ai.pockethost.io
# Misma URL, usada en el servidor (server components / route handlers)
POCKETBASE_URL=https://msc-excel-ai.pockethost.io

# Credenciales de superusuario de PocketBase. Solo se usan server-to-server
# (webhook de cierre, app/api/webhooks/processing-result) — nunca viajan
# al cliente ni al orchestrator.
POCKETBASE_ADMIN_EMAIL=admin@tudominio.com
POCKETBASE_ADMIN_PASSWORD=cambia-esto-por-una-contraseña-fuerte

# ─────────────────────────────────────────────────────────────
# Orchestrator (API de correo en el Droplet) — DEBE ser https
# El navegador sube los archivos directo aquí (sin pasar por Vercel).
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ORCHESTRATOR_URL=https://api-correo.tudominio.com

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
# URL pública del frontend (para el redirect del OAuth). En local: http://localhost:3000
APP_URL=http://localhost:3000

# Secreto compartido con el orchestrator (UPLOAD_TICKET_SECRET allí).
# Generar con: openssl rand -base64 48
UPLOAD_TICKET_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Secreto del webhook de CIERRE (orchestrator -> Next.js), DISTINTO del de
# arriba (límites de confianza distintos: uno es por-usuario y de corta
# duración, este es server-to-server y de larga duración). Debe ser
# EXACTAMENTE el mismo valor que RESULT_WEBHOOK_SECRET en el .env del
# orchestrator. Generar con: openssl rand -base64 48
RESULT_WEBHOOK_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ─────────────────────────────────────────────────────────────
# Allowlist de acceso (herramienta interna). Vacío = permite a cualquiera.
# ─────────────────────────────────────────────────────────────
# Dominios permitidos (coma-separados), ej: dinardi.com.ar,witworks.cloud
ALLOWED_EMAIL_DOMAINS=
# Emails individuales permitidos (coma-separados), ej: alguien@gmail.com
ALLOWED_EMAILS=

# ─────────────────────────────────────────────────────────────
# Cron de SLA (app/api/cron/mark-stale, ver vercel.json). Vercel setea
# automáticamente Authorization: Bearer <esto> en cada invocación cuando
# esta env existe. Generar con: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────
CRON_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ─────────────────────────────────────────────────────────────
# B2B multi-tenant (ver docs del modelo corporativo)
# ─────────────────────────────────────────────────────────────
# Rollout del gate de suscripción en app/api/upload-ticket: off | log | enforce.
# Default seguro: "log" (valida y loguea, no bloquea todavía).
SUBSCRIPTION_GATE_MODE=log

# Email de invitación a empresa (lib/mailer.ts): NO hay SMTP propio acá —
# se reusa el que ya está configurado en el orchestrator de verito, vía
# POST /send-invitation-email. Mismo valor que INVITATION_EMAIL_SECRET en
# el .env del orchestrator (Droplet). Generar con: openssl rand -base64 48
# Si queda vacío, el flujo de invitar sigue funcionando (el link se genera
# igual), solo no se envía el correo — se loguea una advertencia.
INVITATION_EMAIL_SECRET=

# ─────────────────────────────────────────────────────────────
# Web Push (Fase 2, docs/notificaciones-push-plan.md)
# ─────────────────────────────────────────────────────────────
# Par de claves VAPID para firmar los envíos de Web Push. Generar con:
# npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY es intencionalmente PÚBLICA (es la mitad
# pública del esquema VAPID, se usa desde el navegador para suscribirse).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY nunca debe exponerse al cliente — solo se usa server-side
# (lib/push.ts) para firmar los envíos.
VAPID_PRIVATE_KEY=
# Contacto del remitente, requerido por el estándar VAPID (mailto: o https:).
VAPID_SUBJECT=mailto:soporte@dinardi.com.ar
# Si NEXT_PUBLIC_VAPID_PUBLIC_KEY o VAPID_PRIVATE_KEY quedan vacíos, el
# feature degrada en silencio: no se manda Web Push todavía, sin romper el
# resto de notificaciones (in-app + email).
