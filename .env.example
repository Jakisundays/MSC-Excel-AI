# ─────────────────────────────────────────────────────────────
# PocketBase (Pockethost)
# ─────────────────────────────────────────────────────────────
# URL pública de tu instancia de Pockethost
NEXT_PUBLIC_POCKETBASE_URL=https://msc-excel-ai.pockethost.io
# Misma URL, usada en el servidor (server components / route handlers)
POCKETBASE_URL=https://msc-excel-ai.pockethost.io

# ─────────────────────────────────────────────────────────────
# Orchestrator (API de correo en el Droplet) — DEBE ser https
# El navegador sube los archivos directo aquí (sin pasar por Vercel).
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ORCHESTRATOR_URL=https://api-correo.tudominio.com

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
# URL pública del frontend (para el redirect del OAuth). En local: http://localhost:3000
APP_URL=http://localhost:3000

# Secreto compartido con el orchestrator (UPLOAD_TICKET_SECRET allí).
# Generar con: openssl rand -base64 48
UPLOAD_TICKET_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ─────────────────────────────────────────────────────────────
# Allowlist de acceso (herramienta interna). Vacío = permite a cualquiera.
# ─────────────────────────────────────────────────────────────
# Dominios permitidos (coma-separados), ej: dinardi.com.ar,witworks.cloud
ALLOWED_EMAIL_DOMAINS=
# Emails individuales permitidos (coma-separados), ej: alguien@gmail.com
ALLOWED_EMAILS=
